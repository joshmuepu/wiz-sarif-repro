            },
            {
              "id": "CVE-2022-1664",
              "name": "Package vulnerability",
              "shortDescription": {
                "text": "CVE-2022-1664"
              },
              "fullDescription": {
                "text": "Dpkg::Source::Archive in dpkg, the Debian package management system, before version 1.21.8, 1.20.10, 1.19.8, 1.18.26 is prone to a directory traversal vulnerability. When extracting untrusted source packages in v2 and v3 source package formats that include a debian.tar, the in-place extraction can lead to directory traversal situations on specially crafted orig.tar and debian.tar tarballs."
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "helpUri": "https://security-tracker.debian.org/tracker/CVE-2022-1664",
              "properties": {
                "precision": "very-high",
                "security-severity": "9.0",
                "tags": [
                  "vulnerability",
                  "security",
                  "critical"
                ]
              }
            },
            {
              "id": "CVE-2019-20367",
              "name": "Package vulnerability",
              "shortDescription": {
                "text": "CVE-2019-20367"
              },
              "fullDescription": {
                "text": "nlist.c in libbsd before 0.10.0 has an out-of-bounds read during a comparison for a symbol name from the string table (strtab)."
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "helpUri": "https://security-tracker.debian.org/tracker/CVE-2019-20367",
              "properties": {
                "precision": "very-high",
                "security-severity": "9.0",
                "tags": [
                  "vulnerability",
                  "security",
                  "critical",
                  "has-exploit"
                ]
              }
            },
            {
              "id": "CVE-2017-18269",
              "name": "Package vulnerability",
              "shortDescription": {
                "text": "CVE-2017-18269"
              },
              "fullDescription": {
                "text": "An SSE2-optimized memmove implementation for i386 in sysdeps/i386/i686/multiarch/memcpy-sse2-unaligned.S in the GNU C Library (aka glibc or libc6) 2.21 through 2.27 does not correctly perform the overlapping memory check if the source memory range spans the middle of the address space, resulting in corrupt data being produced by the copy operation. This may disclose information to context-dependent attackers, or result in a denial of service, or, possibly, code execution."
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "helpUri": "https://security-tracker.debian.org/tracker/CVE-2017-18269",
              "properties": {
                "precision": "very-high",
                "security-severity": "9.0",
                "tags": [
                  "vulnerability",
                  "security",
                  "critical"
                ]
              }
            },
            {
              "id": "CVE-2019-12450",
              "name": "Package vulnerability",
              "shortDescription": {
                "text": "CVE-2019-12450"
              },
              "fullDescription": {
                "text": "file_copy_fallback in gio/gfile.c in GNOME GLib 2.15.0 through 2.61.1 does not properly restrict file permissions while a copy operation is in progress. Instead, default permissions are used."
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "helpUri": "https://security-tracker.debian.org/tracker/CVE-2019-12450",
              "properties": {
                "precision": "very-high",
